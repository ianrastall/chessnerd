---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolHeader from '../components/ToolHeader.astro';
---
<BaseLayout title="Chess.com API" description="Formatted reference for the Chess.com published-data API documentation.">
<style is:global>
/* ── Layout ─────────────────────────────────────────────────────── */
.api-layout{display:grid;grid-template-columns:210px minmax(0,1fr);gap:2rem;align-items:start;margin-top:1.25rem}

/* ── Sidebar ─────────────────────────────────────────────────────── */
.api-sidebar{position:sticky;top:1rem;max-height:calc(100vh - 2rem);overflow-y:auto;background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:10px;padding:.85rem .75rem;scrollbar-width:thin}
.api-sidebar h4{margin:0 0 .6rem .3rem;font-size:.7rem;text-transform:uppercase;letter-spacing:.1em;color:var(--text-secondary)}
.toc-group{margin-bottom:.5rem}
.toc-group-label{font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--text-secondary);padding:.45rem .4rem .2rem;border-top:1px solid var(--border-color);margin-top:.25rem}
.toc-link{display:block;padding:.28rem .5rem;border-radius:5px;color:var(--text-secondary);text-decoration:none;font-size:.8rem;line-height:1.35;transition:background .12s,color .12s}
.toc-link:hover{background:rgba(var(--accent-rgb),.08);color:var(--text-primary)}
.toc-link.active{background:rgba(var(--accent-rgb),.14);color:var(--accent)}
.toc-link.sub{padding-left:1rem;font-size:.77rem}
.toc-link.root{font-weight:600;font-size:.82rem}

/* ── Content area ────────────────────────────────────────────────── */
.api-content{min-width:0}
.api-section{margin-bottom:2.25rem}
.api-section-header{display:flex;align-items:center;gap:.55rem;margin-bottom:1.1rem;padding-bottom:.55rem;border-bottom:2px solid var(--border-color)}
.api-section-header h2{margin:0;font-size:1.15rem}
.api-section-header .material-icons{color:var(--accent);font-size:1.2rem}

/* ── Overview intro ──────────────────────────────────────────────── */
.api-intro{background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:10px;padding:1.1rem 1.35rem;line-height:1.65;margin-bottom:0}
.api-intro p,.api-intro li{margin:.35rem 0}
.api-intro ol{padding-left:1.3rem;margin:.5rem 0}
.api-intro p:last-child{margin-bottom:0}

/* ── General use grid ────────────────────────────────────────────── */
.general-grid{display:grid;gap:.75rem}
.general-item{background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:8px;padding:.9rem 1.1rem}
.general-item h3{margin:0 0 .45rem;font-size:.92rem;color:var(--accent)}
.general-item p,.general-item ul,.general-item ol{margin:.35rem 0;line-height:1.6;color:var(--text-primary)}
.general-item ul,.general-item ol{padding-left:1.3rem}
.ci{font-family:Consolas,Monaco,monospace;font-size:.86em;background:var(--bg-tertiary);border:1px solid var(--border-color);border-radius:4px;padding:.1em .35em}
.http-codes{display:grid;gap:.35rem;margin:.5rem 0}
.http-code-row{display:flex;gap:.7rem;align-items:baseline;font-size:.88rem;line-height:1.45}
.http-code{font-family:Consolas,Monaco,monospace;font-weight:700;min-width:2.8rem;color:var(--accent)}

/* ── Section intro block ─────────────────────────────────────────── */
.section-intro{background:var(--bg-tertiary);border:1px solid var(--border-color);border-radius:7px;padding:.8rem 1rem;margin-bottom:.85rem;font-size:.88rem;line-height:1.6;color:var(--text-secondary)}
.section-intro code{font-family:Consolas,Monaco,monospace;font-size:.9em}
.section-intro p{margin:.3rem 0}
.section-intro p:first-child{margin-top:0}
.section-intro p:last-child{margin-bottom:0}

/* ── Endpoint cards ──────────────────────────────────────────────── */
.endpoint-cards{display:grid;gap:.85rem}
.endpoint-card{background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:10px;overflow:hidden}
.endpoint-card-head{padding:.8rem 1.1rem .65rem;border-bottom:1px solid var(--border-color);background:linear-gradient(180deg,rgba(var(--accent-rgb),.06),transparent)}
.endpoint-card-head h3{margin:0 0 .3rem;font-size:.97rem}
.endpoint-card-body{padding:.85rem 1.1rem}
.url-pattern{font-family:Consolas,Monaco,monospace;font-size:.82rem;background:var(--bg-tertiary);border:1px solid var(--border-color);border-radius:6px;padding:.55rem .85rem;word-break:break-all;line-height:1.55}
.url-base{color:var(--text-secondary)}
.url-param{color:var(--accent)}
.endpoint-desc{line-height:1.6;color:var(--text-primary);margin:.5rem 0}
.endpoint-note{font-size:.86rem;color:var(--text-secondary);line-height:1.6;margin:.4rem 0;padding-left:.7rem;border-left:3px solid rgba(var(--accent-rgb),.3)}
.endpoint-links{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.8rem;align-items:center}
.endpoint-links a{font-size:.8rem}

/* ── Collapsible data format ─────────────────────────────────────── */
details.df{margin-top:.65rem;border:1px solid var(--border-color);border-radius:7px;overflow:hidden}
details.df summary{cursor:pointer;padding:.5rem .85rem;background:var(--bg-tertiary);font-size:.82rem;font-weight:600;color:var(--text-secondary);list-style:none;display:flex;align-items:center;gap:.4rem;user-select:none}
details.df summary::-webkit-details-marker{display:none}
details.df summary::before{content:"▶";font-size:.6rem;transition:transform .15s;color:var(--accent);flex-shrink:0}
details.df[open] summary::before{transform:rotate(90deg)}
details.df[open] summary{color:var(--text-primary)}
details.df pre{margin:0;padding:.8rem .95rem;max-height:380px;overflow:auto;background:var(--bg-secondary);font-family:Consolas,Monaco,monospace;font-size:.8rem;line-height:1.5;color:var(--text-primary);scrollbar-width:thin}

/* ── Sub-section divider (Player Games) ─────────────────────────── */
.sub-section-header{display:flex;align-items:center;gap:.5rem;margin:1.25rem 0 .75rem;padding-bottom:.45rem;border-bottom:1px dashed var(--border-color)}
.sub-section-header h3{margin:0;font-size:.95rem;color:var(--text-secondary)}
.sub-section-header .material-icons{font-size:1.05rem;color:var(--accent)}

/* ── Downloads bar ───────────────────────────────────────────────── */
.api-downloads{display:flex;gap:.5rem;flex-wrap:wrap;align-items:center;margin-top:.6rem;padding:.65rem .85rem;background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:8px}
.api-downloads span{font-size:.82rem;color:var(--text-secondary);margin-right:.25rem}
.api-downloads a{font-size:.8rem}

/* ── Game results table ──────────────────────────────────────────── */
.results-wrap{background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:10px;overflow:hidden}
.results-table{width:100%;border-collapse:collapse;font-size:.88rem}
.results-table th{text-align:left;padding:.55rem .85rem;background:var(--bg-tertiary);color:var(--text-secondary);font-size:.74rem;text-transform:uppercase;letter-spacing:.06em;border-bottom:2px solid var(--border-color)}
.results-table td{padding:.45rem .85rem;border-bottom:1px solid var(--border-color)}
.results-table tbody tr:last-child td{border-bottom:none}
.results-table td:first-child{font-family:Consolas,Monaco,monospace;font-size:.83rem;color:var(--accent);font-weight:600}
.api-footer-note{margin-top:.85rem;font-size:.82rem;color:var(--text-secondary)}
.api-footer-note a{color:var(--accent)}

/* ── Responsive ──────────────────────────────────────────────────── */
@media(max-width:880px){
  .api-layout{grid-template-columns:1fr}
  .api-sidebar{position:static;max-height:none}
}
</style>

<main>
<div class="tool-container">

  <ToolHeader title="Chess.com API" icon="api" />

  <div class="api-downloads">
    <span>Download:</span>
    <a class="btn btn-secondary btn-compact" href="/downloads/chesscom-api.md" download>
      <span class="material-icons">download</span>Markdown
    </a>
  </div>

  <div class="api-layout">

    <!-- ── Sidebar TOC ──────────────────────────────────────── -->
    <aside class="api-sidebar">
      <h4>Contents</h4>
      <nav aria-label="API sections">

        <div class="toc-group">
          <a class="toc-link root" href="#overview">Overview</a>
        </div>

        <div class="toc-group">
          <div class="toc-group-label">General Use</div>
          <a class="toc-link sub" href="#rate-limits">Rate Limiting</a>
          <a class="toc-link sub" href="#how-to">How to Get the Data</a>
          <a class="toc-link sub" href="#http-responses">HTTP Responses</a>
          <a class="toc-link sub" href="#jsonld">JSON-LD</a>
          <a class="toc-link sub" href="#caching">Caching</a>
        </div>

        <div class="toc-group">
          <div class="toc-group-label">Player Data</div>
          <a class="toc-link sub" href="#player-profile">Profile</a>
          <a class="toc-link sub" href="#titled-players">Titled Players</a>
          <a class="toc-link sub" href="#player-stats">Stats</a>
          <a class="toc-link sub" href="#player-online">Online Status</a>
          <a class="toc-link sub" href="#games-current">Current Games</a>
          <a class="toc-link sub" href="#games-tomove">To-Move</a>
          <a class="toc-link sub" href="#games-archives">Archive List</a>
          <a class="toc-link sub" href="#games-monthly">Monthly Archive</a>
          <a class="toc-link sub" href="#games-pgn">PGN Download</a>
          <a class="toc-link sub" href="#player-clubs">Clubs</a>
          <a class="toc-link sub" href="#player-matches">Matches</a>
          <a class="toc-link sub" href="#player-tournaments">Tournaments</a>
        </div>

        <div class="toc-group">
          <div class="toc-group-label">Clubs</div>
          <a class="toc-link sub" href="#club-profile">Club Profile</a>
          <a class="toc-link sub" href="#club-members">Members</a>
          <a class="toc-link sub" href="#club-matches">Matches</a>
        </div>

        <div class="toc-group">
          <div class="toc-group-label">Tournaments</div>
          <a class="toc-link sub" href="#tournament">Tournament</a>
          <a class="toc-link sub" href="#tournament-round">Round</a>
          <a class="toc-link sub" href="#tournament-group">Round Group</a>
        </div>

        <div class="toc-group">
          <div class="toc-group-label">Team Matches</div>
          <a class="toc-link sub" href="#match-daily">Daily Match</a>
          <a class="toc-link sub" href="#match-daily-board">Daily Board</a>
          <a class="toc-link sub" href="#match-live">Live Match</a>
          <a class="toc-link sub" href="#match-live-board">Live Board</a>
        </div>

        <div class="toc-group">
          <div class="toc-group-label">Countries</div>
          <a class="toc-link sub" href="#country-profile">Country Profile</a>
          <a class="toc-link sub" href="#country-players">Players</a>
          <a class="toc-link sub" href="#country-clubs">Clubs</a>
        </div>

        <div class="toc-group">
          <div class="toc-group-label">Misc</div>
          <a class="toc-link sub" href="#puzzle-daily">Daily Puzzle</a>
          <a class="toc-link sub" href="#puzzle-random">Random Puzzle</a>
          <a class="toc-link sub" href="#streamers">Streamers</a>
          <a class="toc-link sub" href="#leaderboards">Leaderboards</a>
        </div>

        <div class="toc-group">
          <a class="toc-link root" href="#game-results">Game Results Codes</a>
        </div>

      </nav>
    </aside>

    <!-- ── Main content ────────────────────────────────────── -->
    <div class="api-content">

      <!-- Overview -->
      <section id="overview" class="api-section">
        <div class="api-section-header">
          <span class="material-icons" aria-hidden="true">info</span>
          <h2>Overview</h2>
        </div>
        <div class="api-intro">
          <p>The PubAPI is a read-only REST API that responds with JSON-LD data. Its goal is to re-package all currently public data from the website. "Public Data" is information available to people who are not logged in — player data, game data, club/tournament information. Private information restricted to the logged-in user (game chat, conditional moves) is excluded.</p>
          <p>This is <strong>read-only</strong> data. You cannot send game moves or other commands to Chess.com from this system.</p>
          <ol>
            <li>Determine the data you want, and compose the URL based on the endpoint URL pattern.</li>
            <li>Request that URL in your browser, program, <a href="https://www.getpostman.com/" target="_blank" rel="noopener">Postman</a>, cURL, or <a href="https://en.wikipedia.org/wiki/IP_over_Avian_Carriers" target="_blank" rel="noopener">pigeon</a>.</li>
            <li>Enjoy the JSON.</li>
          </ol>
          <p>All time fields are Unix timestamps — the number of <strong>seconds</strong> since January 1, 1970 00:00:00 GMT.</p>
        </div>
      </section>

      <!-- General Use -->
      <section id="general" class="api-section">
        <div class="api-section-header">
          <span class="material-icons" aria-hidden="true">settings</span>
          <h2>General Use</h2>
        </div>
        <div class="general-grid">

          <div class="general-item">
            <h3>Data Currency</h3>
            <p>About 3% of players still use the old "v2" website for some actions. When those players modify data you are requesting, the data may be out of date. This does not apply to mobile app users.</p>
            <p><strong>Default refresh:</strong> endpoints refresh at most once every 24 hours unless otherwise noted.</p>
          </div>

          <div class="general-item">
            <h3>Language</h3>
            <p>URL responses are the same for everyone regardless of who or where they are. In cases where the data contain words (game-ending reasons, error responses), those words will be in English.</p>
          </div>

          <div id="rate-limits" class="general-item">
            <h3>Rate Limiting</h3>
            <p>Serial access rate is unlimited — if you always wait for the previous response before making the next request, you should never encounter rate limiting.</p>
            <p>Parallel requests (threaded apps, webservers handling multiple simultaneous requests) may be blocked. Be prepared to handle a <code class="ci">429 Too Many Requests</code> response for any non-serial request.</p>
            <p>Abnormal or suspicious activity may result in your application being blocked entirely. Supplying a recognizable user-agent with contact information gives Chess.com a way to reach you if a block is necessary.</p>
          </div>

          <div id="how-to" class="general-item">
            <h3>How to Get the Data</h3>
            <p>The PubAPI endpoints can be called by any client or browser that supports HTTP.</p>
            <ul>
              <li><strong>Browser:</strong> paste the endpoint URL directly into the address bar.</li>
              <li><strong>cURL:</strong> <code class="ci">curl -v https://api.chess.com/pub/player/hikaru</code> — returns response code, ETag, date, last-modified, and more.</li>
              <li><strong>Postman / Insomnia:</strong> a <a href="https://www.chess.com/postman/collection-dev.json" target="_blank" rel="noopener">downloadable collection of all endpoints</a> is available from Chess.com.</li>
              <li><strong>jq:</strong> pair with cURL to filter and transform JSON on the command line.</li>
            </ul>
          </div>

          <div id="http-responses" class="general-item">
            <h3>HTTP Responses</h3>
            <div class="http-codes">
              <div class="http-code-row"><span class="http-code">200</span><span>Success — enjoy your JSON</span></div>
              <div class="http-code-row"><span class="http-code">301</span><span>Redirect — URL is bad but Chess.com knows the correct one; update future requests accordingly</span></div>
              <div class="http-code-row"><span class="http-code">304</span><span>Not Modified — cached version is still current (ETag / If-None-Match or Last-Modified / If-Modified-Since)</span></div>
              <div class="http-code-row"><span class="http-code">404</span><span>Not Found — URL is malformed or the data does not exist (e.g., a non-existent username)</span></div>
              <div class="http-code-row"><span class="http-code">410</span><span>Gone — no data will ever be available at this URL; do not request it again</span></div>
              <div class="http-code-row"><span class="http-code">429</span><span>Too Many Requests — rate limit exceeded; see Rate Limiting above</span></div>
            </div>
          </div>

          <div id="jsonld" class="general-item">
            <h3>JSON-LD</h3>
            <p>Each response includes a "linked data" context. JSON-LD is fully compatible with regular JSON. An HTTP <code class="ci">Link</code> header points to the JSON-LD context URL for the data format, helping the data describe its own meaning.</p>
            <h3 style="margin-top:.85rem">JSONP</h3>
            <p>A <code class="ci">callback</code> parameter in any query string is treated as a JavaScript function name to call with the data — useful for <code class="ci">&lt;script&gt;</code> tag usage.</p>
            <p>Example: <code class="ci">https://api.chess.com/pub/player/erik?callback=myFunction</code></p>
            <p>Function names containing non-literal characters or exceeding 200 characters are stripped from the response.</p>
          </div>

          <div id="caching" class="general-item">
            <h3>Caching</h3>
            <p>Each response includes <code class="ci">ETag</code> and <code class="ci">Last-Modified</code> headers. Supply <code class="ci">If-None-Match</code> or <code class="ci">If-Modified-Since</code> in your request to receive a <code class="ci">304 Not Modified</code> response when data has not changed.</p>
            <p>If you request faster than the <code class="ci">Cache-Control</code> max-age, the CDN may respond directly with cached values. Response headers may indicate a cache HIT, MISS, EXPIRED, or REVALIDATED.</p>
            <h3 style="margin-top:.85rem">HTTP Compression &amp; HTTP/2</h3>
            <p>Send <code class="ci">Accept-Encoding: gzip</code> to receive gzip-compressed responses for large payloads (generally &gt;200 bytes) — saving up to 80% of download bandwidth.</p>
            <p>HTTP/2 requests receive HTTP/2 responses: header compression, binary transfer, and multiplexed responses. Note the parallel rate-limiting caveats above.</p>
          </div>

        </div>
      </section>

      <!-- Player Data -->
      <section id="player" class="api-section">
        <div class="api-section-header">
          <span class="material-icons" aria-hidden="true">person</span>
          <h2>Player Data</h2>
        </div>
        <div class="endpoint-cards">

          <div class="endpoint-card" id="player-profile">
            <div class="endpoint-card-head">
              <h3>Player Profile</h3>
              <div class="url-pattern"><span class="url-base">https://api.chess.com/pub/player/</span><span class="url-param">&#123;username&#125;</span></div>
            </div>
            <div class="endpoint-card-body">
              <p class="endpoint-desc">Get additional details about a player.</p>
              <details class="df">
                <summary>Data Format</summary>
                <pre>{`{
  "@id": "URL",        // the location of this profile (always self-referencing)
  "url": "URL",        // the chess.com user's profile page
  "username": "string",
  "player_id": 41,     // the non-changing Chess.com ID of this player
  "title": "string",   // (optional) abbreviation of chess title, if any
  "status": "string",  // closed, closed:fair_play_violations, basic, premium, mod, staff
  "name": "string",    // (optional) personal first and last name
  "avatar": "URL",     // (optional) URL of a 200x200 image
  "location": "string",// (optional) city or location
  "country": "URL",    // API location of this player's country's profile
  "joined": 1178556600,
  "last_online": 1500661803,
  "followers": 17,
  "is_streamer": "boolean",
  "twitch_url": "Twitch.tv URL",
  "fide": "integer"
}`}</pre>
              </details>
              <p class="endpoint-note">The <code class="ci">player_id</code> is a convenience for detecting username changes. If a retrieved Profile has a player_id matching one you previously downloaded, the new Profile replaces the old. This ID will never change for a given account, though its future availability is not guaranteed.</p>
              <div class="endpoint-links">
                <a class="btn btn-secondary btn-compact" href="https://api.chess.com/pub/player/erik" target="_blank" rel="noopener"><span class="material-icons">open_in_new</span>Example</a>
                <a class="btn btn-secondary btn-compact" href="https://api.chess.com/context/Player.jsonld" target="_blank" rel="noopener">JSON-LD Context</a>
              </div>
            </div>
          </div>

          <div class="endpoint-card" id="titled-players">
            <div class="endpoint-card-head">
              <h3>Titled Players</h3>
              <div class="url-pattern"><span class="url-base">https://api.chess.com/pub/titled/</span><span class="url-param">&#123;title-abbrev&#125;</span></div>
            </div>
            <div class="endpoint-card-body">
              <p class="endpoint-desc">List of titled-player usernames.</p>
              <p class="endpoint-note">Valid title abbreviations: GM, WGM, IM, WIM, FM, WFM, NM, WNM, CM, WCM.</p>
              <details class="df">
                <summary>Data Format</summary>
                <pre>{`{
  "players": [
    /* array of usernames for players with this title */
  ]
}`}</pre>
              </details>
              <div class="endpoint-links">
                <a class="btn btn-secondary btn-compact" href="https://api.chess.com/pub/titled/GM" target="_blank" rel="noopener"><span class="material-icons">open_in_new</span>Example</a>
                <a class="btn btn-secondary btn-compact" href="https://api.chess.com/context/Players.jsonld" target="_blank" rel="noopener">JSON-LD Context</a>
              </div>
            </div>
          </div>

          <div class="endpoint-card" id="player-stats">
            <div class="endpoint-card-head">
              <h3>Player Stats</h3>
              <div class="url-pattern"><span class="url-base">https://api.chess.com/pub/player/</span><span class="url-param">&#123;username&#125;</span><span class="url-base">/stats</span></div>
            </div>
            <div class="endpoint-card-body">
              <p class="endpoint-desc">Ratings, win/loss, and other stats about a player's game play, tactics, lessons, and Puzzle Rush score.</p>
              <p class="endpoint-note">The response contains "stats objects" identified by rules code + underscore + time-class code (e.g., <code class="ci">chess_daily</code>, <code class="ci">chess960_blitz</code>). If a player has not played a particular game type, no stats object is present.</p>
              <details class="df">
                <summary>Data Format — Response Wrapper</summary>
                <pre>{`{
  "chess_daily": { /* stats object for chess / daily */ },
  "chess960_daily": { /* stats object for chess960 / daily */ },
  "chess_blitz": { /* stats object for chess / blitz */ },
  /* additional game-type keys as applicable */
  "tactics": {
    "highest": { "rating": "integer", "date": "timestamp" },
    "lowest":  { "rating": "integer", "date": "timestamp" }
  },
  "lessons": {
    "highest": { "rating": "integer", "date": "timestamp" },
    "lowest":  { "rating": "integer", "date": "timestamp" }
  },
  "puzzle_rush": {
    "daily": { "total_attempts": "integer", "score": "integer" },
    "best":  { "total_attempts": "integer", "score": "integer" }
  }
}`}</pre>
              </details>
              <details class="df">
                <summary>Data Format — Each Game-Type Stats Object</summary>
                <pre>{`{
  "last": {
    "date": 1509709165,    // timestamp of the last rated game finished
    "rating": 1642,        // most-recent rating
    "rd": 58               // Glicko "RD" value used to calculate ratings changes
  },
  "best": {
    "date": 1256228875,
    "rating": 2065,        // highest rating achieved
    "game": "URL"          // URL of the best-win game
  },
  "record": {
    "win": 177,
    "loss": 124,
    "draw": 21,
    "time_per_move": 18799,     // seconds per average move
    "timeout_percent": 9.99     // timeout percentage in the last 90 days
  },
  "tournament": {
    "count": 20,
    "withdraw": 1,
    "points": 39,
    "highest_finish": 1
  }
}`}</pre>
              </details>
              <p class="endpoint-note">Stats objects only contain information that has been collected and is not at a default value. Tactics, Lessons, and Puzzle Rush stats may be absent depending on player activity.</p>
              <div class="endpoint-links">
