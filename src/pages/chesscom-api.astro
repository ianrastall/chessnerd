<script>
// Active TOC link tracking via IntersectionObserver
const links = Array.from(document.querySelectorAll('.toc-link[href^="#"]'));
if (links.length) {
  const targets = links.map(l => document.getElementById(l.getAttribute('href').slice(1))).filter(Boolean);
  let active: Element | null = null;
  function setActive(el: Element) {
    if (active === el) return;
    active = el;
    links.forEach(l => l.classList.remove('active'));
    const link = document.querySelector(`.toc-link[href="#${el.id}"]`);
    if (link) link.classList.add('active');
  }
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) setActive(e.target); });
  }, { rootMargin: '0px 0px -55% 0px', threshold: 0 });
  targets.forEach(t => obs.observe(t));
}
</script>
