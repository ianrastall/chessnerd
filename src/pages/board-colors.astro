---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolHeader from '../components/ToolHeader.astro';
---
<BaseLayout title="Board Colors" description="Design a Merida-compatible chessboard color palette and export an empty board as SVG or PNG.">
  <style is:global>
.designer-grid { display:grid; grid-template-columns:minmax(280px,360px) minmax(0,1fr); gap:1.5rem; }
        .board-card,.meta-card{ background:linear-gradient(180deg, rgba(var(--accent-rgb,76,175,80),0.1), transparent 30%), var(--bg-tertiary); border:1px solid var(--border-color); border-radius:12px; box-shadow:0 16px 40px rgba(0,0,0,0.18); }
        .board-card{ padding:1.25rem; }
        .meta-card{ padding:1rem; margin-top:1.5rem; }
        .card-head h3{ margin:0; font-size:1.08rem; }
        .card-head p{ margin:0.4rem 0 1rem; color:var(--text-secondary); line-height:1.5; }
        .slider-stack{ display:grid; gap:1rem; }
        .slider-box,.status-box,.metric-box,.swatch{ border:1px solid var(--border-color); border-radius:10px; background:rgba(255,255,255,0.03); }
        .slider-box{ padding:0.9rem 1rem 1rem; }
        .slider-head{ display:flex; justify-content:space-between; gap:1rem; margin-bottom:0.6rem; align-items:center; }
        .slider-head label{ font-weight:600; }
        .slider-num{ min-width:3.4rem; text-align:center; font-variant-numeric:tabular-nums; padding:0.3rem 0.7rem; border-radius:999px; background:rgba(0,0,0,0.22); font-weight:700; }
        .slider-box input{ width:100%; }
        .red{ accent-color:#d64747; } .green{ accent-color:#47a35d; } .blue{ accent-color:#477bd6; } .vibrancy{ accent-color:#d6a447; } .brightness{ accent-color:#e7c96e; } .contrast{ accent-color:#8f6de7; } .gamma{ accent-color:#d66ec5; } .hue{ accent-color:#4fc8c8; } .warmth{ accent-color:#e77954; }
        .swatches{ display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:0.75rem; margin-top:1rem; }
        .swatch-fill{ height:84px; }
        .swatch-copy{ padding:0.7rem; }
        .swatch-copy small{ display:block; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.3rem; }
        .swatch-copy strong{ font-family:Consolas, monospace; font-size:0.92rem; }
        .status-box{ margin-top:1rem; padding:1rem; }
        .status-row{ display:flex; justify-content:space-between; gap:1rem; align-items:center; margin-bottom:0.5rem; }
        .status-pill{ display:inline-flex; min-width:6.2rem; justify-content:center; padding:0.35rem 0.75rem; border-radius:999px; font-size:0.82rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; }
        .status-pill.ok{ background:rgba(70,187,111,0.18); color:#97f0b3; }
        .status-pill.dark{ background:rgba(255,167,38,0.18); color:#ffd18a; }
        .status-pill.light{ background:rgba(255,138,101,0.18); color:#ffc2b0; }
        .status-box p{ margin:0; color:var(--text-secondary); line-height:1.5; }
        .metrics{ display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:0.7rem; margin-top:0.9rem; }
        .metric-box{ padding:0.7rem 0.8rem; background:rgba(0,0,0,0.18); }
        .metric-box small{ display:block; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.2rem; }
        .metric-box strong{ font-variant-numeric:tabular-nums; }
        .preview-shell{ padding:1rem; border-radius:18px; background:radial-gradient(circle at top, rgba(255,255,255,0.08), transparent 36%), linear-gradient(160deg, rgba(0,0,0,0.14), rgba(0,0,0,0.28)), var(--bg-secondary); border:1px solid rgba(255,255,255,0.06); }
        .board-wrap{ width:min(100%,720px); margin:0 auto; filter:drop-shadow(0 18px 34px rgba(0,0,0,0.32)); }
        .board-wrap svg{ display:block; width:100%; height:auto; }
        .preview-actions{ display:flex; flex-wrap:wrap; gap:0.75rem; justify-content:space-between; align-items:center; margin-top:1rem; }
        .preview-actions p{ margin:0; color:var(--text-secondary); line-height:1.5; }
        .buttons{ display:flex; flex-wrap:wrap; gap:0.75rem; }
        .meta-card textarea{ width:100%; min-height:280px; resize:vertical; margin-top:0.8rem; padding:1rem; border-radius:10px; border:1px solid var(--border-color); background:var(--bg-secondary); color:var(--text-primary); font-family:Consolas, monospace; line-height:1.5; }
        @media (max-width:980px){ .designer-grid{ grid-template-columns:1fr; } }
        @media (max-width:640px){ .swatches,.metrics{ grid-template-columns:1fr; } .buttons{ width:100%; } .buttons .btn{ flex:1 1 180px; justify-content:center; } }
  </style>

  <main>
    <div id="toolView">
                    <ToolHeader title="Board Colors" icon="palette" />
    
                    <div class="designer-grid">
                        <section class="board-card">
                            <div class="card-head">
                                <h3>Dark Square Input</h3>
                                <p>Choose the dark square with RGB, then fine-tune the palette with vibrancy, brightness, contrast, gamma, hue, and warmth. Border and light square colors are derived automatically while preserving the order Border &lt; Dark Square &lt; Light Square.</p>
                            </div>
                            <div class="slider-stack">
                                <div class="slider-box"><div class="slider-head"><label for="redSlider">Red</label><span id="redValue" class="slider-num">118</span></div><input id="redSlider" class="red" type="range" min="0" max="255" value="118"></div>
                                <div class="slider-box"><div class="slider-head"><label for="greenSlider">Green</label><span id="greenValue" class="slider-num">150</span></div><input id="greenSlider" class="green" type="range" min="0" max="255" value="150"></div>
                                <div class="slider-box"><div class="slider-head"><label for="blueSlider">Blue</label><span id="blueValue" class="slider-num">86</span></div><input id="blueSlider" class="blue" type="range" min="0" max="255" value="86"></div>
                                <div class="slider-box"><div class="slider-head"><label for="vibrancySlider">Vibrancy</label><span id="vibrancyValue" class="slider-num">100%</span></div><input id="vibrancySlider" class="vibrancy" type="range" min="0" max="200" value="100"></div>
                                <div class="slider-box"><div class="slider-head"><label for="brightnessSlider">Brightness</label><span id="brightnessValue" class="slider-num">100%</span></div><input id="brightnessSlider" class="brightness" type="range" min="0" max="200" value="100"></div>
                                <div class="slider-box"><div class="slider-head"><label for="contrastSlider">Contrast</label><span id="contrastSettingValue" class="slider-num">100%</span></div><input id="contrastSlider" class="contrast" type="range" min="0" max="200" value="100"></div>
                                <div class="slider-box"><div class="slider-head"><label for="gammaSlider">Gamma</label><span id="gammaValue" class="slider-num">1.00</span></div><input id="gammaSlider" class="gamma" type="range" min="50" max="200" value="100"></div>
                                <div class="slider-box"><div class="slider-head"><label for="hueSlider">Hue</label><span id="hueValue" class="slider-num">0°</span></div><input id="hueSlider" class="hue" type="range" min="-180" max="180" value="0"></div>
                                <div class="slider-box"><div class="slider-head"><label for="warmthSlider">Warmth</label><span id="warmthValue" class="slider-num">0</span></div><input id="warmthSlider" class="warmth" type="range" min="-100" max="100" value="0"></div>
                            </div>
                            <div class="swatches">
                                <article class="swatch"><div id="borderSwatch" class="swatch-fill"></div><div class="swatch-copy"><small>Border</small><strong id="borderCode">#000000</strong></div></article>
                                <article class="swatch"><div id="darkSwatch" class="swatch-fill"></div><div class="swatch-copy"><small>Dark Square</small><strong id="darkCode">#769656</strong></div></article>
                                <article class="swatch"><div id="lightSwatch" class="swatch-fill"></div><div class="swatch-copy"><small>Light Square</small><strong id="lightCode">#000000</strong></div></article>
                            </div>
                            <div class="status-box" aria-live="polite">
                                <div class="status-row"><strong id="statusLabel">Palette Status: OK</strong><span id="statusPill" class="status-pill ok">OK</span></div>
                                <p id="statusCopy">The selected dark square sits in a usable luminance range for board contrast.</p>
                                <div class="metrics">
                                    <div class="metric-box"><small>Relative Luminance</small><strong id="luminanceValue">0.000</strong></div>
                                    <div class="metric-box"><small>Contrast Span</small><strong id="contrastValue">0.000</strong></div>
                                </div>
                            </div>
                        </section>
    
                        <section class="board-card">
                            <div class="card-head">
                                <h3>Board Preview</h3>
                                <p>The border contains algebraic coordinates on all four sides, centered in the middle of the border thickness and aligned to the adjacent square centers.</p>
                            </div>
                            <div class="preview-shell"><div id="boardPreview" class="board-wrap" aria-live="polite"></div></div>
                            <div class="preview-actions">
                                <p>The export buttons generate the active empty board as SVG or PNG.</p>
                                <div class="buttons">
                                    <button id="downloadSvgBtn" class="btn btn-primary" type="button"><span class="material-icons">download</span>Download SVG Board</button>
                                    <button id="downloadPngBtn" class="btn btn-secondary" type="button"><span class="material-icons">image</span>Download PNG Board</button>
                                </div>
                            </div>
                        </section>
                    </div>
    
                    <section class="meta-card">
                        <div class="card-head">
                            <h3>Generated Palette Metadata</h3>
                            <p>Read-only output with exact HEX, RGB, luminance, and matching HTML color names when an exact named color exists.</p>
                        </div>
                        <textarea id="metadataOutput" readonly spellcheck="false"></textarea>
                    </section>
    
                    <div class="status-bar"><div id="statusMessage" class="success">Palette ready</div></div>
                </div>
  </main>

  <script is:inline>
const NAMED = {"#000000":"Black","#000080":"Navy","#0000FF":"Blue","#008000":"Green","#008080":"Teal","#00FF00":"Lime","#00FFFF":"Aqua","#800000":"Maroon","#800080":"Purple","#808000":"Olive","#808080":"Gray","#C0C0C0":"Silver","#FF0000":"Red","#FF00FF":"Fuchsia","#FFFF00":"Yellow","#FFFFFF":"White"};
        const COORD_HEX = "#F3F3F3";
        const SIZE = { square: 84, border: 34 };
        const TOTAL = SIZE.square * 8 + SIZE.border * 2;
        const FILES = ["a","b","c","d","e","f","g","h"];
        const RANKS = ["8","7","6","5","4","3","2","1"];
        const redSlider = document.getElementById("redSlider");
        const greenSlider = document.getElementById("greenSlider");
        const blueSlider = document.getElementById("blueSlider");
        const vibrancySlider = document.getElementById("vibrancySlider");
        const brightnessSlider = document.getElementById("brightnessSlider");
        const contrastSlider = document.getElementById("contrastSlider");
        const gammaSlider = document.getElementById("gammaSlider");
        const hueSlider = document.getElementById("hueSlider");
        const warmthSlider = document.getElementById("warmthSlider");
        const redValue = document.getElementById("redValue");
        const greenValue = document.getElementById("greenValue");
        const blueValue = document.getElementById("blueValue");
        const vibrancyValue = document.getElementById("vibrancyValue");
        const brightnessValue = document.getElementById("brightnessValue");
        const contrastSettingValue = document.getElementById("contrastSettingValue");
        const gammaValue = document.getElementById("gammaValue");
        const hueValue = document.getElementById("hueValue");
        const warmthValue = document.getElementById("warmthValue");
        const borderSwatch = document.getElementById("borderSwatch");
        const darkSwatch = document.getElementById("darkSwatch");
        const lightSwatch = document.getElementById("lightSwatch");
        const borderCode = document.getElementById("borderCode");
        const darkCode = document.getElementById("darkCode");
        const lightCode = document.getElementById("lightCode");
        const boardPreview = document.getElementById("boardPreview");
        const metadataOutput = document.getElementById("metadataOutput");
        const statusLabel = document.getElementById("statusLabel");
        const statusPill = document.getElementById("statusPill");
        const statusCopy = document.getElementById("statusCopy");
        const luminanceValue = document.getElementById("luminanceValue");
        const contrastValue = document.getElementById("contrastValue");
        const statusMessage = document.getElementById("statusMessage");
        const downloadSvgBtn = document.getElementById("downloadSvgBtn");
        const downloadPngBtn = document.getElementById("downloadPngBtn");
        let currentSvg = "";

        function clamp(v, min, max) { return Math.min(Math.max(v, min), max); }
        function hexPart(v) { return clamp(Math.round(v), 0, 255).toString(16).padStart(2, "0").toUpperCase(); }
        function rgbToHex(r, g, b) { return `#${hexPart(r)}${hexPart(g)}${hexPart(b)}`; }
        function hexToRgb(hex) { const c = hex.replace("#", ""); return { r: parseInt(c.slice(0, 2), 16), g: parseInt(c.slice(2, 4), 16), b: parseInt(c.slice(4, 6), 16) }; }
        function toRgbText(rgb) { return `rgb(${rgb.r}, ${rgb.g}, ${rgb.b})`; }
        function named(hex) { return NAMED[hex.toUpperCase()] || "No exact HTML color name"; }
        function fmtSigned(value, suffix = "") { return `${value > 0 ? "+" : ""}${value}${suffix}`; }
        function wrapHue(h) { return ((h % 1) + 1) % 1; }

        function rgbToHsl(r, g, b) {
            r /= 255; g /= 255; b /= 255;
            const max = Math.max(r, g, b), min = Math.min(r, g, b), l = (max + min) / 2, d = max - min;
            if (!d) return { h: 0, s: 0, l };
            const s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
            let h = max === r ? ((g - b) / d + (g < b ? 6 : 0)) : max === g ? ((b - r) / d + 2) : ((r - g) / d + 4);
            return { h: h / 6, s, l };
        }

        function hslToRgb(h, s, l) {
            if (!s) { const gray = Math.round(l * 255); return { r: gray, g: gray, b: gray }; }
            const q = l < 0.5 ? l * (1 + s) : l + s - l * s;
            const p = 2 * l - q;
            const hue = (t) => {
                let x = t;
                if (x < 0) x += 1;
                if (x > 1) x -= 1;
                if (x < 1 / 6) return p + (q - p) * 6 * x;
                if (x < 1 / 2) return q;
                if (x < 2 / 3) return p + (q - p) * (2 / 3 - x) * 6;
                return p;
            };
            return { r: Math.round(hue(h + 1 / 3) * 255), g: Math.round(hue(h) * 255), b: Math.round(hue(h - 1 / 3) * 255) };
        }

        function lin(channel) {
            const v = channel / 255;
            return v <= 0.04045 ? v / 12.92 : ((v + 0.055) / 1.055) ** 2.4;
        }

        function luminance(rgb) { return 0.2126 * lin(rgb.r) + 0.7152 * lin(rgb.g) + 0.0722 * lin(rgb.b); }

        function applyWarmth(rgb, warmthAmount) {
            const warmth = warmthAmount / 100;
            return {
                r: clamp(rgb.r + (38 * warmth), 0, 255),
                g: clamp(rgb.g + (12 * warmth), 0, 255),
                b: clamp(rgb.b - (44 * warmth), 0, 255)
            };
        }

        function applyBrightnessContrastGamma(rgb, brightnessPercent, contrastPercent, gammaSetting) {
            const brightness = brightnessPercent / 100;
            const contrast = contrastPercent / 100;
            const gamma = gammaSetting / 100;
            const invGamma = 1 / Math.max(gamma, 0.01);

            function adjust(channel) {
                let value = (channel / 255) * brightness;
                value = ((value - 0.5) * contrast) + 0.5;
                value = clamp(value, 0, 1);
                value = Math.pow(value, invGamma);
                return Math.round(clamp(value, 0, 1) * 255);
            }

            return {
                r: adjust(rgb.r),
                g: adjust(rgb.g),
                b: adjust(rgb.b)
            };
        }

        function derive(baseDark, controls) {
            const warmed = applyWarmth(baseDark, controls.warmth);
            const inputHsl = rgbToHsl(warmed.r, warmed.g, warmed.b);
            const adjustedHue = wrapHue(inputHsl.h + (controls.hue / 360));
            const adjustedSat = clamp(inputHsl.s * (controls.vibrancy / 100), 0, 0.95);
            const hueAdjusted = hslToRgb(adjustedHue, adjustedSat, inputHsl.l);
            const dark = applyBrightnessContrastGamma(hueAdjusted, controls.brightness, controls.contrast, controls.gamma);
            const darkHsl = rgbToHsl(dark.r, dark.g, dark.b);
            const borderSat = clamp(darkHsl.s * 0.92, 0, 0.88);
            const lightSat = clamp(darkHsl.s * 0.78, 0, 0.82);
            const border = hslToRgb(darkHsl.h, borderSat, clamp(darkHsl.l - 0.18, 0.06, Math.max(0.07, darkHsl.l - 0.06)));
            const light = hslToRgb(darkHsl.h, lightSat, clamp(darkHsl.l + 0.22, Math.min(0.92, darkHsl.l + 0.08), 0.92));
            return { border, dark, light, darkHsl, inputHsl, warmed, hueAdjusted };
        }

        function paletteStatus(luma) {
            if (luma < 0.11) return { label: "Too Dark", cls: "dark", copy: "The dark square is unusually dark. The hierarchy is preserved, but the board may feel heavy." };
            if (luma > 0.42) return { label: "Too Light", cls: "light", copy: "The dark square is unusually bright. The hierarchy is preserved, but the board may feel washed out." };
            return { label: "OK", cls: "ok", copy: "The selected dark square sits in a usable luminance range for board contrast." };
        }

        function boardSvg(palette) {
            const square = SIZE.square, border = SIZE.border, total = TOTAL, font = 20;
            const textBase = `fill="${COORD_HEX}" font-family="Roboto, Arial, sans-serif" font-size="${font}" font-weight="700" text-anchor="middle" dominant-baseline="middle"`;
            const out = [`<svg xmlns="http://www.w3.org/2000/svg" width="${total}" height="${total}" viewBox="0 0 ${total} ${total}" role="img" aria-label="Empty chessboard with surrounding coordinates">`,`<rect width="${total}" height="${total}" fill="${palette.borderHex}"/>`];
            for (let row = 0; row < 8; row += 1) {
                for (let col = 0; col < 8; col += 1) {
                    const x = border + col * square, y = border + row * square, fill = (row + col) % 2 === 0 ? palette.lightHex : palette.darkHex;
                    out.push(`<rect x="${x}" y="${y}" width="${square}" height="${square}" fill="${fill}"/>`);
                }
            }
            FILES.forEach((file, i) => {
                const x = border + (i + 0.5) * square, topY = border / 2, bottomY = total - border / 2;
                out.push(`<text x="${x}" y="${topY}" ${textBase}>${file}</text>`);
                out.push(`<text x="${x}" y="${bottomY}" ${textBase}>${file}</text>`);
            });
            RANKS.forEach((rank, i) => {
                const y = border + (i + 0.5) * square, leftX = border / 2, rightX = total - border / 2;
                out.push(`<text x="${leftX}" y="${y}" ${textBase}>${rank}</text>`);
                out.push(`<text x="${rightX}" y="${y}" ${textBase}>${rank}</text>`);
            });
            out.push("</svg>");
            return out.join("");
        }

        function saveBlob(blob, name) {
            const url = URL.createObjectURL(blob);
            const a = document.createElement("a");
            a.href = url;
            a.download = name;
            document.body.appendChild(a);
            a.click();
            a.remove();
            setTimeout(() => URL.revokeObjectURL(url), 500);
        }

        function setBar(message, type) { statusMessage.textContent = message; statusMessage.className = type; }

        function render() {
            const baseDark = { r: Number(redSlider.value), g: Number(greenSlider.value), b: Number(blueSlider.value) };
            const controls = {
                vibrancy: Number(vibrancySlider.value),
                brightness: Number(brightnessSlider.value),
                contrast: Number(contrastSlider.value),
                gamma: Number(gammaSlider.value),
                hue: Number(hueSlider.value),
                warmth: Number(warmthSlider.value)
            };
            redValue.textContent = baseDark.r;
            greenValue.textContent = baseDark.g;
            blueValue.textContent = baseDark.b;
            vibrancyValue.textContent = `${controls.vibrancy}%`;
            brightnessValue.textContent = `${controls.brightness}%`;
            contrastSettingValue.textContent = `${controls.contrast}%`;
            gammaValue.textContent = (controls.gamma / 100).toFixed(2);
            hueValue.textContent = fmtSigned(controls.hue, "°");
            warmthValue.textContent = fmtSigned(controls.warmth);
            const palette = derive(baseDark, controls);
            const borderHex = rgbToHex(palette.border.r, palette.border.g, palette.border.b);
            const darkHex = rgbToHex(palette.dark.r, palette.dark.g, palette.dark.b);
            const lightHex = rgbToHex(palette.light.r, palette.light.g, palette.light.b);
            const borderLum = luminance(palette.border), darkLum = luminance(palette.dark), lightLum = luminance(palette.light);
            const status = paletteStatus(darkLum);

            borderSwatch.style.background = borderHex; darkSwatch.style.background = darkHex; lightSwatch.style.background = lightHex;
            borderCode.textContent = borderHex; darkCode.textContent = darkHex; lightCode.textContent = lightHex;
            statusLabel.textContent = `Palette Status: ${status.label}`;
            statusPill.textContent = status.label;
            statusPill.className = `status-pill ${status.cls}`;
            statusCopy.textContent = status.copy;
            luminanceValue.textContent = darkLum.toFixed(3);
            contrastValue.textContent = (lightLum - borderLum).toFixed(3);

            currentSvg = boardSvg({ borderHex, darkHex, lightHex });
            boardPreview.innerHTML = currentSvg;
            metadataOutput.value = [
                "Board Colors Palette","====================","",
                `Palette Status: ${status.label}`,
                `Base Input RGB: ${toRgbText(baseDark)}`,
                `Vibrancy (Saturation): ${controls.vibrancy}%`,
                `Brightness: ${controls.brightness}%`,
                `Contrast: ${controls.contrast}%`,
                `Gamma: ${(controls.gamma / 100).toFixed(2)}`,
                `Hue Shift: ${fmtSigned(controls.hue, "°")}`,
                `Warmth: ${fmtSigned(controls.warmth)}`,
                `Dark Square Luminance: ${darkLum.toFixed(6)}`,
                `Palette Contrast Span: ${(lightLum - borderLum).toFixed(6)}`,"",
                "Border",`  HEX: ${borderHex}`,`  RGB: ${toRgbText(palette.border)}`,`  HTML Name: ${named(borderHex)}`,`  Relative Luminance: ${borderLum.toFixed(6)}`,"",
                "Dark Square",`  HEX: ${darkHex}`,`  RGB: ${toRgbText(palette.dark)}`,`  HTML Name: ${named(darkHex)}`,`  Relative Luminance: ${darkLum.toFixed(6)}`,"",
                "Light Square",`  HEX: ${lightHex}`,`  RGB: ${toRgbText(palette.light)}`,`  HTML Name: ${named(lightHex)}`,`  Relative Luminance: ${lightLum.toFixed(6)}`,"",
                "Coordinates",`  HEX: ${COORD_HEX}`,`  RGB: ${toRgbText(hexToRgb(COORD_HEX))}`,`  HTML Name: ${named(COORD_HEX)}`,"",
                "Board Geometry",`  Square Size: ${SIZE.square}px`,`  Border Thickness: ${SIZE.border}px`,`  Export Size: ${TOTAL} x ${TOTAL}px`
            ].join("\n");
            setBar(`Palette synced: ${darkHex} dark squares`, "success");
        }

        function downloadSvg() {
            saveBlob(new Blob([currentSvg], { type: "image/svg+xml;charset=utf-8" }), "chess-nerd-board-colors.svg");
            setBar("SVG board downloaded", "success");
        }

        function downloadPng() {
            const svgBlob = new Blob([currentSvg], { type: "image/svg+xml;charset=utf-8" });
            const url = URL.createObjectURL(svgBlob);
            const img = new Image();
            img.onload = () => {
                const canvas = document.createElement("canvas");
                canvas.width = TOTAL; canvas.height = TOTAL;
                const ctx = canvas.getContext("2d");
                ctx.drawImage(img, 0, 0);
                URL.revokeObjectURL(url);
                canvas.toBlob((blob) => {
                    if (!blob) { setBar("PNG export failed", "error"); return; }
                    saveBlob(blob, "chess-nerd-board-colors.png");
                    setBar("PNG board downloaded", "success");
                }, "image/png");
            };
            img.onerror = () => { URL.revokeObjectURL(url); setBar("PNG export failed", "error"); };
            img.src = url;
        }

        [redSlider, greenSlider, blueSlider, vibrancySlider, brightnessSlider, contrastSlider, gammaSlider, hueSlider, warmthSlider].forEach((slider) => slider.addEventListener("input", render));
        downloadSvgBtn.addEventListener("click", downloadSvg);
        downloadPngBtn.addEventListener("click", downloadPng);
        render();
  </script>
</BaseLayout>
