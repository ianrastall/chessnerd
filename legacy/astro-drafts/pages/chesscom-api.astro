---
import { readFileSync } from 'node:fs';
import BaseLayout from '../layouts/BaseLayout.astro';

const source = readFileSync(new URL('../../legacy/static-site/chesscom-api.html', import.meta.url), 'utf8');
const mainHtml = source.match(/<main[^>]*>([\s\S]*?)<\/main>/i)?.[1]?.trim() ?? '';
const styleMatches = Array.from(source.matchAll(/<style[^>]*>([\s\S]*?)<\/style>/gi)) as RegExpMatchArray[];
const styles = styleMatches
  .map((match) => match[1].trim())
  .filter(Boolean)
  .join('\n\n');

const afterMain = source.slice(source.search(/<\/main>/i));
const scriptMatches = Array.from(afterMain.matchAll(/<script([^>]*)>([\s\S]*?)<\/script>/gi)) as RegExpMatchArray[];
const scripts = scriptMatches
  .map((match) => {
    const attrs = match[1];
    const body = match[2].trim();
    const src = attrs.match(/src=["']([^"']+)["']/i)?.[1];

    if (src === 'js/theme.js') return '';
    if (src) {
      const normalized = src.startsWith('js/') ? `/${src}` : src;
      return `<scr` + `ipt src="${normalized}"></scr` + `ipt>`;
    }

    return body ? `<scr` + `ipt>${body}</scr` + `ipt>` : '';
  })
  .filter(Boolean)
  .join('\n');
---
<BaseLayout title="Chess.com API" description="Formatted reference for the Chess.com published-data API documentation.">
  {styles && <style is:global set:html={styles}></style>}
  <main set:html={mainHtml}></main>
  <Fragment set:html={scripts} />
</BaseLayout>
